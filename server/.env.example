# Server
PORT=3001
# Render sets NODE_ENV=production automatically. Locally, leave unset (defaults to development).
NODE_ENV=

# Provided by the preview runtime — NOT user secrets:
#   MONGO_URI   — connection string for the per-preview Mongo sidecar. Must be MongoDB Atlas —
#                 vector search (RAG retrieval) requires it. After setting it, run the
#                 one-time `npm run setup:vector-index` to create the Atlas Vector Search index.
#   CLIENT_DIST — path to the built client the server serves (single-origin). Leave unset when
#                 the client is deployed as its own separate Render static site — set CORS_ORIGIN
#                 instead so the server accepts requests from it.

# CORS_ORIGIN — required when client and server are separate Render services. Set this to the
# client's exact deployed origin, e.g. https://your-client.onrender.com (no trailing slash).
# Leave unset only for same-origin/local dev — it then reflects any request's Origin, which is
# fine for dev but not for a production deploy with two separate domains.
CORS_ORIGIN=

# App-internal secrets — platform auto-generates and injects these (do NOT ask the user)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# RILO Managed AI — platform-injected, never ask the user
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# RILO Managed Storage (S3-compatible) — platform-injected, never ask the user
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_KEY_PREFIX=

# RILO Managed Email (Resend) — platform-injected, never ask the user
RESEND_API_KEY=
EMAIL_FROM=

# MongoDB Atlas Vector Search — name of the index created by `npm run setup:vector-index`
VECTOR_INDEX_NAME=vector_index
