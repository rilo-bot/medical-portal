# Only needed when the API is hosted as a separate service from this client (e.g. two Render
# services). Set to the deployed server's exact origin, no trailing slash, no /api suffix.
# Leave unset for local dev (the Vite proxy forwards /api to http://localhost:3001) or for
# same-origin serving (the server serves this built client itself via CLIENT_DIST).
VITE_API_BASE_URL=https://your-server.onrender.com
